---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import AnimatedGradientBackground from '@/components/ui/AnimatedGradientBackground.astro';
import CategoryIcon from '@/components/ui/CategoryIcon.astro';
import CategoryTitle from '@/components/ui/CategoryTitle.astro';
import LanguageIcon from '@/components/ui/LanguageIcon.astro';
import SectionTitle from '@/components/ui/SectionTitle.astro';
import UnifiedButton from '@/components/ui/UnifiedButton.astro';
import { sectionsColors } from '@/data/sectionBackgrounds';
import { languages } from '@/i18n/ui';
import { getLangFromUrl, getTranslations, processMarkdown, translatePath } from '@/i18n/utils';
import BaseLayout from '@/layouts/BaseLayout.astro';

export function getStaticPaths() {
    return Object.keys(languages).map((lang) => ({
        params: { lang }
    }));
}

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);

// Get all collections
const allSnippets = await getCollection('snippets');
const allCssTricks = await getCollection('css-tricks');
const allUsefulLinks = await getCollection('useful-links');

// Sort and get featured/recent items (max 3 per category)

const featuredSnippets: CollectionEntry<'snippets'>[] = allSnippets
    .sort((a: CollectionEntry<'snippets'>, b: CollectionEntry<'snippets'>) => {
        if (a.data.featured && !b.data.featured) return -1;
        if (!a.data.featured && b.data.featured) return 1;
        return b.data.createdAt.getTime() - a.data.createdAt.getTime();
    })
    .slice(0, 6);

const featuredCssTricks: CollectionEntry<'css-tricks'>[] = allCssTricks
    .sort((a: CollectionEntry<'css-tricks'>, b: CollectionEntry<'css-tricks'>) => {
        if (a.data.featured && !b.data.featured) return -1;
        if (!a.data.featured && b.data.featured) return 1;
        return b.data.createdAt.getTime() - a.data.createdAt.getTime();
    })
    .slice(0, 6);

// Sort by filename (which has numeric prefix like "01-name")
const featuredLinks: CollectionEntry<'useful-links'>[] = allUsefulLinks
    .sort((a: CollectionEntry<'useful-links'>, b: CollectionEntry<'useful-links'>) => {
        return a.id.localeCompare(b.id);
    })
    .slice(0, 12);

// Helper to get localized description for useful-links
const getLinkDescription = (link: CollectionEntry<'useful-links'>) => {
    return lang === 'es' ? link.data.description_es : link.data.description_en;
};

// Helper to get localized description for snippets
const getSnippetDescription = (snippet: CollectionEntry<'snippets'>) => {
    return lang === 'es' ? snippet.data.description_es : snippet.data.description_en;
};

// Helper to clean numeric prefix from slug (e.g., "async/01-sleep" -> "async/sleep")
const cleanSlug = (slug: string) => slug.replace(/\/\d+-/, '/');

const title = t('goodies.title', { markdown: false });
const description = t('goodies.subtitle', { markdown: false });
const goodiesPageDescription = processMarkdown(t('goodies.pageDescription'));

const categories = [
    {
        id: 'snippets' as const,
        title: t('goodies.categories.snippets'),
        description: processMarkdown(t('snippets.pageDescription')),
        items: featuredSnippets,
        total: allSnippets.length,
        href: translatePath('/goodies/snippets', lang),
        viewAllLabel: t('goodies.dropdown.viewAllSnippets')
    },
    {
        id: 'css-tricks' as const,
        title: t('goodies.categories.cssTricks'),
        description: processMarkdown(t('cssTricks.pageDescription')),
        items: featuredCssTricks,
        total: allCssTricks.length,
        href: translatePath('/goodies/css-tricks', lang),
        viewAllLabel: t('goodies.dropdown.viewAllCssTricks')
    },
    {
        id: 'useful-links' as const,
        title: t('goodies.categories.usefulLinks'),
        description: processMarkdown(t('usefulLinks.pageDescription')),
        items: featuredLinks,
        total: allUsefulLinks.length,
        href: translatePath('/goodies/useful-links', lang),
        viewAllLabel: t('goodies.dropdown.viewAllLinks')
    }
];
---

<BaseLayout title={title} description={description}>
    <div class="relative section overflow-hidden pt-32" style={`background-color: ${sectionsColors.goodies}`}>
        <AnimatedGradientBackground />

        <div class="container-custom">
            <!-- Header -->
            <div class="mb-16">
                <SectionTitle title={t('goodies.title', { markdown: true })} subtitle={t('goodies.subtitle', { markdown: true })} size="2xl" />

                <!-- Page Description -->
                <div class="mt-8 text-sm text-foreground-secondary max-w-3xl mx-auto leading-relaxed text-center" set:html={goodiesPageDescription} />
            </div>

            <!-- Categories Grid -->
            <div class="space-y-16">
                {categories.map((category) => (
                    <section>
                        <!-- Category Header -->
                        <div class="mb-8">
                            <div class="flex items-center justify-between mb-5">
                                <CategoryTitle text={category.title} count={category.total}>
                                    <CategoryIcon slot="icon" name={category.id} size={28} />
                                </CategoryTitle>
                                <UnifiedButton href={category.href} variant="outline" size="sm" iconPosition="right">
                                    <span set:html={category.viewAllLabel} />
                                    <Fragment slot="icon-right">
                                        <svg class="w-full h-full" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                        </svg>
                                    </Fragment>
                                </UnifiedButton>
                            </div>
                            <p class="text-sm text-foreground-secondary max-w-3xl leading-relaxed" set:html={category.description} />
                        </div>

                        <!-- Items Preview -->
                        {category.items.length > 0 ? (
                            <div class={`grid gap-4 ${category.id === 'useful-links' ? 'grid-cols-1 md:grid-cols-2 lg:grid-cols-4' : 'grid-cols-1 md:grid-cols-3'}`}>
                                {category.id === 'snippets' && featuredSnippets.map((snippet) => (
                                    <a
                                        href={translatePath(`/goodies/snippets/${cleanSlug(snippet.slug)}`, lang)}
                                        class="goodies-card group relative overflow-hidden rounded-2xl border border-foreground/10 bg-card p-6 transition-all duration-300 hover:border-primary/30 hover:shadow-xl hover:shadow-primary/10 hover:-translate-y-1"
                                    >
                                        <!-- Decorative gradient background -->
                                        <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-secondary/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" />

                                        <!-- Decorative code bracket -->
                                        <div class="absolute -right-4 -top-4 text-primary/[0.06] pointer-events-none select-none">
                                            <svg class="w-24 h-24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                                                <path d="M8 3H7a2 2 0 0 0-2 2v5a2 2 0 0 1-2 2 2 2 0 0 1 2 2v5c0 1.1.9 2 2 2h1" />
                                                <path d="M16 21h1a2 2 0 0 0 2-2v-5c0-1.1.9-2 2-2a2 2 0 0 1-2-2V5a2 2 0 0 0-2-2h-1" />
                                            </svg>
                                        </div>

                                        <!-- Language badge with icon -->
                                        <div class="relative z-10 flex items-center gap-2 mb-4">
                                            <div class="flex items-center gap-2 px-2.5 py-1.5 rounded-lg bg-primary/10 border border-primary/20">
                                                <LanguageIcon name={snippet.data.language} size={16} class="text-primary" />
                                                <span class="text-xs font-semibold text-primary">
                                                    {snippet.data.language}
                                                </span>
                                            </div>
                                        </div>

                                        <!-- Title & Description -->
                                        <div class="relative z-10">
                                            <h3 class="font-bold text-lg mb-2 group-hover:text-primary transition-colors">{snippet.data.name}</h3>
                                            <p class="text-sm text-foreground-secondary line-clamp-2 leading-relaxed">{getSnippetDescription(snippet)}</p>
                                        </div>

                                        <!-- Arrow indicator -->
                                        <div class="absolute bottom-4 right-4 opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-x-2 group-hover:translate-x-0">
                                            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                            </svg>
                                        </div>
                                    </a>
                                ))}

                                {category.id === 'css-tricks' && featuredCssTricks.map((trick) => (
                                    <a
                                        href={translatePath(`/goodies/css-tricks/${trick.slug}`, lang)}
                                        class="goodies-card group relative overflow-hidden rounded-2xl border border-foreground/10 bg-card p-6 transition-all duration-300 hover:border-primary/30 hover:shadow-xl hover:shadow-primary/10 hover:-translate-y-1"
                                    >
                                        <!-- Decorative gradient background -->
                                        <div class="absolute inset-0 bg-gradient-to-br from-[#264de4]/5 via-transparent to-[#2965f1]/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" />

                                        <!-- Decorative CSS icon -->
                                        <div class="absolute -right-3 -top-3 text-[#264de4]/[0.08] pointer-events-none select-none">
                                            <svg class="w-20 h-20" viewBox="0 0 24 24" fill="currentColor">
                                                <path d="M1.5 0h21l-1.91 21.563L11.977 24l-8.565-2.438L1.5 0zm17.09 4.413L5.41 4.41l.213 2.622 10.125.002-.255 2.716h-6.64l.24 2.573h6.182l-.366 3.523-2.91.804-2.956-.81-.188-2.11h-2.61l.29 3.855L12 19.288l5.373-1.53L18.59 4.414z"/>
                                            </svg>
                                        </div>

                                        <!-- CSS badge -->
                                        <div class="relative z-10 flex items-center gap-2 mb-4">
                                            <div class="flex items-center gap-2 px-2.5 py-1.5 rounded-lg bg-[#264de4]/10 border border-[#264de4]/20">
                                                <CategoryIcon name="css-tricks" size={16} class="text-[#264de4]" />
                                                <span class="text-xs font-semibold text-[#264de4]">CSS</span>
                                            </div>
                                        </div>

                                        <!-- Title & Description -->
                                        <div class="relative z-10">
                                            <h3 class="font-bold text-lg mb-2 group-hover:text-primary transition-colors line-clamp-1">{trick.data.title}</h3>
                                            <p class="text-sm text-foreground-secondary line-clamp-2 leading-relaxed">{trick.data.description}</p>
                                        </div>

                                        <!-- Arrow indicator -->
                                        <div class="absolute bottom-4 right-4 opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-x-2 group-hover:translate-x-0">
                                            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                            </svg>
                                        </div>
                                    </a>
                                ))}

                                {category.id === 'useful-links' && featuredLinks.map((link) => (
                                    <a
                                        href={link.data.url}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="goodies-card group relative overflow-hidden rounded-xl border border-foreground/10 bg-card p-4 transition-all duration-300 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 hover:-translate-y-0.5"
                                    >
                                        <!-- Decorative gradient background -->
                                        <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-secondary/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" />

                                        <!-- Category indicator line -->
                                        <div class="absolute left-0 top-0 bottom-0 w-0.5 bg-primary/20 group-hover:bg-primary transition-colors duration-300" />

                                        <div class="relative z-10 pl-2">
                                            <h3 class="font-semibold mb-1.5 group-hover:text-primary transition-colors flex items-center gap-2 text-sm">
                                                {link.data.name}
                                                <svg class="w-3 h-3 opacity-40 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                                </svg>
                                            </h3>
                                            <p class="text-xs text-foreground-secondary line-clamp-2 leading-relaxed">{getLinkDescription(link)}</p>
                                        </div>
                                    </a>
                                ))}
                            </div>
                        ) : (
                            <div class="text-center py-12 rounded-xl border border-foreground/10 bg-card">
                                <p class="text-foreground-secondary">Coming soon...</p>
                            </div>
                        )}
                    </section>
                ))}
            </div>
        </div>
    </div>
</BaseLayout>

<style>
    .line-clamp-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
